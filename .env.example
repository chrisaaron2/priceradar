# ===========================================
# PriceRadar Environment Variables
# Copy this file to .env and fill in your values
# ===========================================

# --- eBay API (Chris - Track A) ---
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id

# --- Best Buy (Chris - Track A) ---
# Best Buy API requires corporate email (blocks free/.edu addresses).
# Using synthetic data generator instead. No API key needed.

# --- AWS S3 (Chris - Track A) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=priceradar-raw

# --- PostgreSQL (Shared) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=priceradar
POSTGRES_USER=priceradar
POSTGRES_PASSWORD=priceradar_dev

# --- GCP / BigQuery (Punith - Track B) ---
GCP_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- LLM API (Chris - Track A: SKU Matching) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Airflow (Chris - Track A) ---
AIRFLOW__CORE__FERNET_KEY=your_fernet_key
AIRFLOW__CORE__LOAD_EXAMPLES=False

# --- MLflow (Punith - Track B) ---
MLFLOW_TRACKING_URI=http://localhost:5000
